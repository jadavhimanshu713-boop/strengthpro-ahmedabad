    <section id="services">
        <h2>🏋️ Our Services</h2>
        <div class="services-grid">
            <div class="service">
                <h3>🚚 Equipment Supply</h3>
                <p>Complete Bull Strength range - Lat Pull Down, Leg Press, Chest Press, Shoulder Press</p>
            </div>
            <div class="service">
                <h3>🔧 Installation</h3>
                <p>Professional gym setup anywhere in Ahmedabad. 24hrs service!</p>
            </div>
            <div class="service">
                <h3>🛠️ AMC & Repair</h3>
                <p>Annual maintenance contract. All Bull Strength machines covered.</p>
            </div>
            <div class="service">
                <h3>⚙️ Customization</h3>
                <p>Custom gym layouts for your space. Plate loaded & pin loaded options.</p>
            </div>
        </div>
    </section>

    <section id="equipments">
        <h2>⚙️ Bull Strength Equipments</h2>
        <div id="equip-list" class="equipments">
            <!-- Dynamic content -->
        </div>
        
        <div id="admin-panel">
            <h3>🔐 Admin Panel - Manage Inventory</h3>
            <button onclick="toggleLogin()">Admin Login</button>
            <div id="login-section" style="display:none;">
                <div class="login-form">
                    <input type="text" id="admin-user" placeholder="Username">
                    <input type="password" id="admin-pass" placeholder="Password">
                    <button onclick="adminLogin()">Login</button>
                </div>
            </div>
            <div id="admin-section" style="display:none;">
                <div class="login-form">
                    <input type="text" id="equip-name" placeholder="Equipment Name">
                    <textarea id="equip-desc" placeholder="Description & Price"></textarea>
                    <input type="text" id="equip-img" placeholder="Image URL (optional)">
                    <button onclick="addEquipment()">➕ Add Equipment</button>
                    <button onclick="adminLogout()">🚪 Logout</button>
                </div>
            </div>
        </div>
    </section>

    <section id="contact">
        <h2>📞 Contact StrengthPro Ahmedabad</h2>
        <div class="contact-info">
            <div class="phone-number">6355 175 955</div>
            <p><strong>👨 Owner:</strong> Rohan Dohare</p>
            <p><strong>📍 Location:</strong> Ahmedabad, Gujarat</p>
            <p><strong>📧 Email:</strong> contact@strengthproahmedabad.com</p>
            <p><strong>🕒 Service:</strong> 24/7 Emergency | Installation: Mon-Sat</p>
        </div>
    </section>

    <footer>
        <p>© 2026 StrengthPro Ahmedabad | Rohan Dohare | All Bull Strength equipments covered</p>
        <p>Gym Equipment Sales | Service | Installation | Ahmedabad</p>
    </footer>

    <script>
        // Complete equipment list from catalog
        let equipments = [
            {name: 'Lat Pull Down Single Pulley', desc: 'Bull Strength back machine. Perfect pull workouts. ₹85,000', img: ''},
            {name: 'Chest Press Plate Loaded', desc: 'Heavy duty chest development. Commercial grade. ₹1,25,000', img: ''},
            {name: '45° Leg Press w/ Safety', desc: 'Full leg workout with safety lock. ₹2,10,000', img: ''},
            {name: 'Shoulder Press Dual Handle', desc: 'Plate loaded shoulder machine. ₹95,000', img: ''},
            {name: 'Seated Leg Curl', desc: 'Pin loaded hamstring specialist. ₹75,000', img: ''},
            {name: 'Hack Squat', desc: 'Quad focused heavy duty. ₹1,85,000', img: ''}
        ];

        let isAdmin = false;

        function renderEquipments() {
            document.getElementById('equip-list').innerHTML = equipments.map((equip, index) => `
                <div class="equip">
                    <div style="height:200px;background:linear-gradient(45deg,#4CAF50,#45a049);border-radius:10px;display:flex;align-items:center;justify-content:center;color:white;font-size:3rem;">${getIcon(equip.name)}</div>
                    <h3>${equip.name}</h3>
                    <p>${equip.desc}</p>
                    <button onclick="quickCall()" style="background:#ff6b35;">📞 Enquiry</button>
                </div>
            `).join('');
        }

        function getIcon(name) {
            if(name.includes('Chest')) return '💪';
            if(name.includes('Leg')) return '🦵';
            if(name.includes('Pull')) return '💥';
            if(name.includes('Shoulder')) return '🛡️';
            return '⚙️';
        }

        function quickCall() {
            window.location.href = 'tel:6355175955';
        }

        function toggleLogin() {
            document.getElementById('login-section').style.display = 'block';
        }

        function adminLogin() {
            const user = document.getElementById('admin-user').value;
            const pass = document.getElementById('admin-pass').value;
            if(user === 'admin' && pass === 'rohan123') {
                isAdmin = true;
                document.getElementById('login-section').style.display = 'none';
                document.getElementById('admin-section').style.display = 'block';
                alert('✅ Admin login successful!');
            } else {
                alert('❌ Wrong credentials!');
            }
        }

        function addEquipment() {
            const name = document.getElementById('equip-name').value;
            const desc = document.getElementById('equip-desc').value;
            const img = document.getElementById('equip-img').value;
            
            if(name && desc) {
                equipments.push({name, desc, img});
                renderEquipments();
                document.getElementById('equip-name').value = '';
                document.getElementById('equip-desc').value = '';
                alert('✅ Equipment added!');
            }
        }

        function adminLogout() {
            isAdmin = false;
            document.getElementById('admin-section').style.display = 'none';
            document.getElementById('login-section').style.display = 'none';
        }

        // Smooth scrolling
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        // SEO: Save to localStorage
        if(!localStorage.getItem('strengthpro_equipments')) {
            localStorage.setItem('strengthpro_equipments', JSON.stringify(equipments));
        }

        // Initial render
        renderEquipments();
    </script>
</body>
