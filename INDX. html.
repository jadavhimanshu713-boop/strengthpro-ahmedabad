            <li><a href="#" onclick="toggleAdmin()">🔐 Admin</a></li>
        </ul>
    </nav>

    <section id="home" class="hero">
        <div class="hero-content">
            <h2>Ahmedabad's #1 Gym Equipment Partner</h2>
            <p>Premium Bull Strength machines with expert installation & lifetime service support. 100+ gyms trust us!</p>
            <a href="#contact" class="cta-button">📲 Call Now: 6355175955</a>
        </div>
