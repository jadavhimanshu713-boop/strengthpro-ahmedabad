        h2 { font-size: 2.5rem; text-align: center; margin-bottom: 2rem; color: #1e3c72; }
        .services-grid, .equipments { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }
        .service, .equip { background: white; border-radius: 15px; padding: 2rem; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.1); transition: transform 0.3s; }
        .service:hover, .equip:hover { transform: translateY(-10px); }
        .equip img { width: 100%; height: 200px; object-fit: cover; border-radius: 10px; margin-bottom: 1rem; background: #f0f0f0; }
        #admin-panel { display: none; background: #e8f5e8; padding: 2rem; border-radius: 15px; margin: 2rem 0; }
        .login-form, #admin-form { max-width: 400px; margin: 1rem auto; }
        input, button, textarea, select { width: 100%; padding: 0.8rem; margin: 0.5rem 0; border: 1px solid #ddd; border-radius: 5px; font-size: 1rem; }
        button { background: #ff6b35; color: white; border: none; cursor: pointer; font-weight: bold; transition: background 0.3s; }
        button:hover { background: #e55a2b; }
        .contact-info { background: #f8f9fa; padding: 2rem; border-radius: 15px; text-align: center; }
        .phone-number { font-size: 2rem; font-weight: bold; color: #ff6b35; display: block; margin: 1rem 0; }
        footer { background: #1e3c72; color: white; text-align: center; padding: 2rem; }
        @media (max-width: 768px) { .hero-content h2 { font-size: 2rem; } nav ul { flex-direction: column; align-items: center; } }
